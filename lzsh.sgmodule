#!name=乐仔生活库存巡检
#!desc=发现有现金库存弹窗，无库存静默
#!arguments-desc= CRON定时: 运行时间，默认8点到23点，每30分钟运行一次。
#!arguments=CRON定时设置:"*/30 8-23 * * *"
[Script]
乐仔生活库存巡检 = type=cron,cronexp="{{{CRON定时设置}}}",timeout=60,script-path=https://raw.githubusercontent.com/yuhuohua/jb/refs/heads/main/lzsh.js,script-update-interval=0
