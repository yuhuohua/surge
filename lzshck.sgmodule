#!name=乐仔生活 Token 检测
#!desc=支持多账号，自定义标签。检测 Token 是否失效，失效弹窗提醒，正常静默运行。参数格式：标签&Token
#!category=〈ザㄩメ火华
#!author=〈ザㄩメ火华
#!arguments-desc=[配置参数]\n\n⓵ CRON定时: 运行时间\n\n⓶ 账号参数: 格式为 标签&Token，如：张三&eyJ0e...\n
#!arguments=CRON定时设置:"0 9 * * *",账号1:"",账号2:"",账号3:"",账号4:"",账号5:"",账号6:"",账号7:"",账号8:"",账号9:"",账号10:""

[Script]
乐仔Token检测 = type=cron, cronexp="{{{CRON定时设置}}}", script-path=lzshck.js, wake-system=1, timeout=60, argument={{{账号1}}}#{{{账号2}}}#{{{账号3}}}#{{{账号4}}}#{{{账号5}}}#{{{账号6}}}#{{{账号7}}}#{{{账号8}}}#{{{账号9}}}#{{{账号10}}}
