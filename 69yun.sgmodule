#!name=69云机场签到(多账号版)
#!desc=支持最多5个账号，可静默运行
#!category=每日提醒
#!author=〈ザㄩメ火华
#!arguments-desc=[配置参数]\n\n⓵ CRON定时: 运行时间（默认早上9点运行）\n⓶ 账号格式: 邮箱:密码，多个账号分别填入不同字段，示例：123123@gmail.com:123123\n 静默运行: 静默运行 (填 # 则静默不通知，留空则正常弹出通知)
#!arguments=CRON定时设置:"0 9 * * *",静默运行:"",账号和密码1:"",账号和密码2:"",账号和密码3:"",账号和密码4:"",账号和密码5:""

[Script]
69云多账号签到 = type=cron, cronexp="{{{CRON定时设置}}}", script-path=https://raw.githubusercontent.com/yuhuohua/jb/refs/heads/main/69yun.js, wake-system=1, timeout=90, argument={{{账号和密码1}}}#{{{账号和密码2}}}#{{{账号和密码3}}}#{{{账号和密码4}}}#{{{账号和密码5}}} &silent={{{静默运行}}}