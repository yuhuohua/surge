[Script]
获取登录Token = type=http-response, pattern=^https:\/\/xcx\.tianjiguan\.cn\/api\/user\/autoLogin, requires-body=1, script-path=https://raw.githubusercontent.com/yuhuohua/jb/refs/heads/main/tjgtk.js

[MITM]
hostname = %APPEND% xcx.tianjiguan.cn

