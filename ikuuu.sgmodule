#!name=ikuuu 签到
#!desc=每日自动签到，邮箱:密码
#!category=工具
#!author=yourname
#!arguments-desc=[配置参数]\n\n⓵ CRON定时: 运行时间（默认早上9点）\n⓶ 账号: 邮箱:密码，示例: 123456@qq.com:123456\n 静默运行: 填 # 则静默不通知，留空则正常弹出通知
#!arguments=CRON定时设置:"0 9 * * *",静默运行:"",账号和密码:""

[Script]
ikuuu签到 = type=cron, cronexp="{{{CRON定时设置}}}", script-path=ik.js, wake-system=1, timeout=30, argument={{{账号和密码}}}&silent={{{静默运行}}}