#!name=越狱插件更新检测
#!desc=定时查询越狱源(Sileo/Cydia)插件更新状态，支持多源并发查询，可自定义20个插件参数。
#!author=〈ザㄩメ火华
#!category=〈ザㄩメ火华
#!arguments-desc=[配置参数]\n\n⓵ CRON定时设置: 每天运行的时间 (默认早上8点到晚上11点，每1个小时运行一次)\n\n⓶ 插件数据 (最高支持20个): \n格式: 名称@包名(BundleID)@源地址@图标\n(注: 源地址尽量填写包含 Packages 文件的直接根目录，图标选填)\n\n示例1: FLEX 3@com.johncoates.flex3@https://vxbaker.com/repo@🛠️\n示例2: 巨魔商店@com.opa334.trollstore@https://havoc.app\n\n请在上面按需填入插件信息，留空的参数槽会自动忽略。
#!arguments=CRONEXP:"0 8-23/1 * * *",插件1:"",插件2:"",插件3:"",插件4:"",插件5:"",插件6:"",插件7:"",插件8:"",插件9:"",插件10:"",插件11:"",插件12:"",插件13:"",插件14:"",插件15:"",插件16:"",插件17:"",插件18:"",插件19:"",插件20:""

[Script]
越狱插件检测 = type=cron, cronexp="{{{CRONEXP}}}", script-path=https://raw.githubusercontent.com/yuhuohua/jb/refs/heads/main/sileojc.js, wake-system=1, timeout=120, argument=apps={{{插件1}}};{{{插件2}}};{{{插件3}}};{{{插件4}}};{{{插件5}}};{{{插件6}}};{{{插件7}}};{{{插件8}}};{{{插件9}}};{{{插件10}}};{{{插件11}}};{{{插件12}}};{{{插件13}}};{{{插件14}}};{{{插件15}}};{{{插件16}}};{{{插件17}}};{{{插件18}}};{{{插件19}}};{{{插件20}}}
